name: data_split

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      input_artifact: string
      test_size: float
      random_seed: int
      stratify_by: string
    command: "python run.py --input_artifact {input_artifact} --test_size {test_size} --random_seed {random_seed} --stratify_by {stratify_by}"