name: train_random_forest

conda_env: conda.yml

entry_points:
  main:
    parameters:
      trainval_artifact: string
      rf_config: string
      output_artifact: string
      random_seed: int
    command: "python run.py --trainval_artifact {trainval_artifact} --rf_config {rf_config} --output_artifact {output_artifact} --random_seed {random_seed}"